{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Style Studio",
  "version": "0.1.0",
  "identifier": "de.michelyweb.imagestylestudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image Style Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "nsis",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwRTUyNEU2RDI3RkY3OEIKUldTTDkzL1M1aVRsVUNaZjZtakpCU3pIYzVBOHQ5RjREL3NmbmxlMDFtdWFLNWo4L0g2d0JyV2MK",
      "endpoints": [
        "https://github.com/Jehu/ai-image-generator/releases/latest/download/latest.json"
      ]
    }
  }
}
