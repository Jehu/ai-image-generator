# Optionale Konfiguration für die Desktop-App (Dev-Modus: .env im Projekt-Root).
# In der installierten App alternativ: config.json im App-Data-Verzeichnis
# (flaches JSON-Objekt mit denselben Schlüsseln). Env-Variablen haben Vorrang.

# OpenRouter API Key (https://openrouter.ai/keys) — PFLICHT für Generierung,
# Stil-Analyse und Style-Briefs. Ein einziger Key für alle Bildmodelle
# (Nano Banana Pro / 2 / 1 = Gemini 3 Pro / 3.1 Flash / 2.5 Flash Image,
# GPT-5 Image, GPT-5 Image Mini).
OPENROUTER_API_KEY=""

# Optionale Attribution-Header für OpenRouter (erscheinen in deren Dashboard).
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_TITLE=""

# Modell für "Stil aus Bild ableiten" (Vision-Analyse über OpenRouter).
# Optional — Default: google/gemini-2.5-flash.
OPENROUTER_ANALYSIS_MODEL=""

# Modell für den Markdown-Style-Brief (Text über OpenRouter).
# Optional — Default: google/gemini-2.5-flash.
OPENROUTER_BRIEF_MODEL=""

# Speicherorte überschreiben (Default: App-Data-Verzeichnis der Desktop-App).
# DATABASE_URL="file:./pfad/zur.db"
# IMAGE_DIR="./data/images"

# Einmalige Übernahme bestehender Web-App-Daten beim ersten Start:
# Verzeichnis, das prisma/data/dev.db und data/images enthält.
# LEGACY_DATA_DIR="/Users/me/coding/ai-image-generator-ui"
